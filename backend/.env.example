# ThutoQuest AI Backend - Environment Configuration Example
# Copy this to .env and update with your values

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=True
ENVIRONMENT=development

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json  # json or text

# ============================================================================
# OPENAI CONFIGURATION
# ============================================================================
# Required for REST of intelligent quest generation features
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_API_TIMEOUT=30

# ============================================================================
# VECTOR DATABASE CONFIGURATION
# ============================================================================
# Options: chroma, pinecone, weaviate, milvus
VECTOR_DB_TYPE=chroma
VECTOR_DB_PATH=./vector_store

# Pinecone (if using Pinecone)
# PINECONE_API_KEY=your-key
# PINECONE_ENVIRONMENT=us-west1-gcp
# PINECONE_INDEX_NAME=thutoquest

# Weaviate (if using Weaviate)
# WEAVIATE_URL=http://localhost:8080

# ============================================================================
# DATABASE CONFIGURATION (PostgreSQL)
# ============================================================================
# In development, can be empty (uses in-memory)
# In production, required for persistence
DATABASE_URL=postgresql://postgres:password@localhost:5432/thutoquest_db
DATABASE_ECHO=false  # Set to true to log SQL queries
DATABASE_POOL_SIZE=20
DATABASE_POOL_MAX_OVERFLOW=0
DATABASE_POOL_RECYCLE=3600

# ============================================================================
# AUTHENTICATION
# ============================================================================
# JWT configuration (for future auth implementation)
SECRET_KEY=your-secret-key-here-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============================================================================
# FEATURE FLAGS
# ============================================================================
ENABLE_RAG=true
ENABLE_CAREER_PREDICTION=true
ENABLE_VECTOR_SEARCH=true
MOCK_DATA_MODE=false  # Use mock data instead of database

# ============================================================================
# CORS CONFIGURATION
# ============================================================================
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
CORS_CREDENTIALS=true
CORS_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_HEADERS=*

# ============================================================================
# MONITORING & OBSERVABILITY
# ============================================================================
# Sentry (optional error tracking)
SENTRY_DSN=

# ============================================================================
# PERFORMANCE
# ============================================================================
# Number of worker processes (set to 4 * num_cores for production)
WORKERS=1
# Request timeout in seconds
REQUEST_TIMEOUT=30
# Cache TTL in seconds
CACHE_TTL=3600
